<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>專屬生日祝福</title>
    <style>
        /* 基礎設定 */
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0a0a1a;
            color: white;
            overflow: hidden; /* 防止滾動條出現 */
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        /* --- 登入介面樣式 --- */
        #login-container {
            text-align: center;
            background: rgba(255, 255, 255, 0.1);
            padding: 50px 40px;
            border-radius: 20px;
            backdrop-filter: blur(15px);
            box-shadow: 0 0 30px rgba(255, 126, 179, 0.3);
            z-index: 10;
        }

        #login-container h1 {
            font-size: 1.8rem;
            margin-bottom: 10px;
        }

        #login-container p {
            color: #ddd;
            margin-bottom: 25px;
        }

        input {
            padding: 12px;
            margin-bottom: 20px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            width: 80%;
            text-align: center;
            background: rgba(255, 255, 255, 0.9);
        }

        button {
            padding: 12px 30px;
            background: linear-gradient(45deg, #ff7eb3, #ff758c);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(255, 117, 140, 0.4);
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 117, 140, 0.6);
        }

        #error-msg {
            color: #ff4d4d;
            margin-top: 15px;
            font-size: 0.9rem;
            display: none;
        }

        /* --- 動畫與祝福頁面樣式 --- */
        #animation-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            display: none; /* 初始隱藏 */
        }

        /* 炫彩雲層 */
        .clouds {
            position: absolute;
            width: 200%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 80%, rgba(255, 126, 179, 0.3) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(126, 196, 255, 0.3) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(186, 104, 200, 0.2) 0%, transparent 60%);
            animation: cloudMove 20s infinite alternate ease-in-out;
            filter: blur(30px);
        }

        @keyframes cloudMove {
            0% { transform: translate(-10%, -5%) scale(1); }
            100% { transform: translate(10%, 5%) scale(1.2); }
        }

        /* 流星動畫 */
        .shooting-star {
            position: absolute;
            top: -100px;
            right: -100px;
            width: 250px;
            height: 2px;
            background: linear-gradient(90deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0) 100%);
            transform: rotate(-45deg);
            opacity: 0;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.8);
        }

        .shooting-star.animate {
            animation: shoot 2.5s ease-out forwards;
            animation-delay: 0.5s;
        }

        @keyframes shoot {
            0% { top: -50px; right: -50px; opacity: 1; }
            100% { top: 70%; right: 110%; opacity: 0; }
        }

        /* 祝福文字 */
        .greeting-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            opacity: 0;
            width: 90%;
        }

        .greeting-text.show {
            animation: fadeInText 3s forwards;
            animation-delay: 2s; /* 等待流星劃過一半後慢慢浮現 */
        }

        .greeting-text h2 {
            font-size: 3.5rem;
            margin-bottom: 15px;
            color: #ffffff;
            text-shadow: 0 0 10px #ff7eb3, 0 0 30px #ff7eb3, 0 0 50px #ff758c;
            letter-spacing: 2px;
        }

        .greeting-text p {
            font-size: 1.5rem;
            color: #e0e0e0;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
        }

        @keyframes fadeInText {
            from { opacity: 0; transform: translate(-50%, -30%); }
            to { opacity: 1; transform: translate(-50%, -50%); }
        }
    </style>
</head>
<body>

    <div id="login-container">
        <h1>🎁 一份神秘的禮物 🎁</h1>
        <p>請輸入密碼來解開你的專屬生日驚喜</p>
        <input type="password" id="password-input" placeholder="請輸入密碼">
        <br>
        <button onclick="unlockSurprise()">解鎖祝福</button>
        <p id="error-msg">密碼錯誤，請再試一次！</p>
    </div>

    <div id="animation-container">
        <div class="clouds"></div>
        
        <div class="shooting-star"></div>
        
        <div class="greeting-text">
            <h2>*** 生日快樂 ***</h2>
            <p>祝你天天開心，心想事成，擁有最美好的一天！✨</p>
        </div>
    </div>

    <script>
        function unlockSurprise() {
            const pwdInput = document.getElementById('password-input').value;
            const errorMsg = document.getElementById('error-msg');
            
            // 【重要】在這裡設定你的專屬密碼，目前我先設定為 "0514"
            const correctPassword = "0516"; 

            if (pwdInput === correctPassword) {
                // 密碼正確：隱藏登入介面
                document.getElementById('login-container').style.display = 'none';
                
                // 顯示動畫介面
                const animContainer = document.getElementById('animation-container');
                animContainer.style.display = 'block';

                // 稍微延遲一下，再為流星和文字加上觸發動畫的 class
                setTimeout(() => {
                    document.querySelector('.shooting-star').classList.add('animate');
                    document.querySelector('.greeting-text').classList.add('show');
                }, 100);

            } else {
                // 密碼錯誤：顯示錯誤訊息
                errorMsg.style.display = 'block';
            }
        }
    </script>
</body>
</html>
